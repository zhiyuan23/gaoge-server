// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户表
// ============================================
model User {
  id        Int        @id @default(autoincrement())
  openid    String     @unique // 微信 openid
  unionid   String?    @unique // 微信 unionid
  nickname  String?    // 昵称
  avatarUrl String?    // 头像
  phone     String?    @unique // 手机号
  role      String     @default("user") // user / admin
  status    String     @default("active") // active / inactive
  deletedAt DateTime?  // 软删除
  lastLoginAt DateTime? // 最后登录时间

  // Token 关联
  refreshTokens RefreshToken[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([openid])
  @@index([phone])
}

// ============================================
// 球员表（足球队员）
// ============================================
model Player {
  id          Int        @id @default(autoincrement())
  openid      String     @unique // 微信openid，必填唯一
  nickname    String     @unique // 昵称，必填唯一
  realName    String?    // 真实姓名，非必填
  avatarUrl   String?    // 头像，非必填
  subTeam     String?    // 子球队：real/inter/united，多选存储为逗号分隔字符串
  birthDate   DateTime?  // 出生年月日，非必填
  isAdmin     Boolean    @default(false) // 是否管理员
  position    String?    // 足球位置，非必填
  jerseySize  String?    // 球衣尺码，非必填
  status      String     @default("active") // active / inactive
  remark      String?    // 备注
  userId      Int?       @unique // 绑定的用户ID

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([openid])
  @@index([nickname])
  @@index([subTeam])
}

// ============================================
// Token 表
// ============================================
model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// 球队资金明细表
// ============================================
model TeamFund {
  id          Int       @id @default(autoincrement())
  type        String    // income (收入) / expense (支出)
  amount      Int       // 金额 (分，存储整数)
  title       String    // 标题
  description String?   // 详细说明
  category    String    // 类别：game_fee(比赛费) / equipment(装备) / venue(场地) / activity(活动) / sponsor(赞助) / other(其他)
  status      String    @default("pending") // pending / confirmed / cancelled
  recordDate  DateTime  // 记录日期
  creatorId   Int?      // 创建者ID (管理员)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([recordDate])
  @@index([status])
}

// ============================================
// 轮播图表
// ============================================
model Banner {
  id       Int       @id @default(autoincrement())
  title    String    // 标题
  imageUrl String    // 图片地址
  linkUrl  String?   // 跳转链接
  sort     Int       @default(0) // 排序
  status   String    @default("active") // active / inactive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sort])
}