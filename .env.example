# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_APPSECRET=your-wechat-appsecret

# JWT配置
JWT_SECRET=your-jwt-secret-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/gaoge_db?schema=public"

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 应用配置
APP_PORT=3000
APP_NAME=gaoge-server
APP_VERSION=1.0.0
NODE_ENV=development

# 安全配置
CORS_ORIGIN=http://localhost:9527,https://gaoge.cc,https://www.gaoge.cc
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
