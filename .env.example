# Copy this file to `.env.local` for local development.
# Production should use a server-side `.env` managed outside git.

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_APPSECRET=your-wechat-appsecret

# JWT 配置
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/gaoge_db?schema=public

# 应用配置
NODE_ENV=development
PORT=3000

# 后台管理员初始化（用于 seed）
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=Admin@123456
